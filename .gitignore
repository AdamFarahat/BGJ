# ========================================
# GLOBAL (works from /fmod/ nested root)
# ========================================

# =========================
# Unity (nested-safe)
# =========================
**/[Ll]ibrary/
**/[Tt]emp/
**/[Oo]bj/
**/[Bb]uild/
**/[Bb]uilds/
**/[Ll]ogs/
**/[Uu]ser[Ss]ettings/
**/[Mm]emoryCaptures/
**/[Rr]ecordings/

# Addressables & Streaming temp
**/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*
**/[Aa]ssets/[Ss]treamingAssets/aa.meta
**/[Aa]ssets/[Ss]treamingAssets/aa/*

# Unity crash
**/sysinfo.txt

# Builds
*.apk
*.aab
*.app
*.unitypackage
*.unitypackage.meta

# =========================
# Visual Studio / Rider
# =========================
.vs/
**/.vs/
.idea/
.consulo/

*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Logs / build artifacts
*.log
*.tlog
*.binlog

# =========================
# VS Code
# =========================
**/.vscode/*
!**/.vscode/settings.json
!**/.vscode/tasks.json
!**/.vscode/launch.json
!**/.vscode/extensions.json

.history/
.ionide/

# =========================
# General temp/cache
# =========================
**/__pycache__/
**/*.pyc
**/.cache/
**/.Cache/
**/Cache/
**/tmp/

# =========================
# FMOD (clean + merged)
# =========================

# FMOD cache
**/[Aa]ssets/Plugins/FMOD/Cache/*

# FMOD banks (generated)
**/[Aa]ssets/StreamingAssets/**/*.bank
**/[Aa]ssets/StreamingAssets/**/*.bank.meta

# General FMOD bank/build folders
**/Banks/**
**/banks/**
**/Build/**
**/build/**

# FMOD metadata/cache
**/Metadata/**

# FMOD logs
**/fmod_editor.log

# =========================
# KEEP (important FMOD files)
# =========================

# Keep FMOD project
!**/*.fspro
!**/*.fspro.meta

# Keep FMOD plugin binaries
!**/[Aa]ssets/Plugins/FMOD/**/lib/*

# Keep FMOD editor assets
!**/[Aa]ssets/Gizmos/FMOD/*
!**/[Aa]ssets/Editor Default Resources/FMOD/*

# Keep core Unity assets
!**/Assets/**
!**/Plugins/**
!**/StreamingAssets/**

# =========================
# Optional (toggle depending on workflow)
# =========================

# If CI builds banks, uncomment:
# **/StreamingAssets/**